sh echo ""
sh echo "[14] Stop probes"
sh touch /tmp/traffic_probe.stop
sh sleep 3
sh pkill -f "/mnt/shared/island_mode/traffic_probe.py" 2>/dev/null || true

sh echo ""
sh echo "[15] Stop watch"
sh bash /mnt/shared/island_mode/stop_watch.sh 2>/dev/null || true

sh echo ""
sh echo "[16] Final OVS status"
sh python3 /mnt/shared/island_mode/edge_mode_controller.py status

sh echo ""
sh echo "[17] Metrics file"
sh wc -l /mnt/shared/results/integrated_metrics.csv
sh tail -n 20 /mnt/shared/results/integrated_metrics.csv

sh echo ""
sh echo "[18] Generate final report data"
sh bash /mnt/shared/island_mode/generate_report_data.sh --mode benchmark --metrics /mnt/shared/results/integrated_metrics.csv --outdir /mnt/shared/results --audit /tmp/island_audit.log

