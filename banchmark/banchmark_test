sh mkdir -p /mnt/shared/results
sh rm -f /mnt/shared/results/integrated_metrics.csv
sh rm -f /tmp/traffic_probe.stop
sh rm -f /tmp/traffic_probe_start
sh echo "NORMAL" > /tmp/island_phase

sh echo ""
sh echo "[1] Start watch for state-driven transitions"
sh bash /mnt/shared/island_mode/stop_watch.sh 2>/dev/null || true
